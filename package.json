    "eslint-plugin-simple-import-sort": "^12.1.1",
    "exifreader": "^4.36.2",
    "js-yaml": "^4.1.1",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.56.1"
