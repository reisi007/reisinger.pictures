    "dayjs": "^1.11.19",
    "photoswipe": "^5.4.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/js": "^10.0.1",
    "@iconify-json/material-symbols": "^1.2.60",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify/tailwind4": "^1.2.3",
