{
  "name": "reisinger.pictures",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "editor:css": "tailwindcss -i ./editor/editor.tw.css -o ./editor/editor.css --watch",
    "human-loop:css": "tailwindcss -i ./human-loop/human-loop.tw.css -o human-loop/human-loop.css --watch",
    "prebuild": "node add-metadata.mjs",
    "postbuild": "node clean_output.mjs && node check_links.mjs",
    "preview": "astro preview",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "publish": "npm run build ",
    "postpublish": "sync.bat",
    "merge:llm": "repomix"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/mdx": "^5.0.2",
    "@astrojs/sitemap": "^3.7.1",
    "@astrojs/solid-js": "^6.0.1",
    "@tailwindcss/cli": "^4.2.2",
    "astro": "^6.0.7",
    "dayjs": "^1.11.20",
    "photoswipe": "^5.4.4",
    "sharp": "^0.34.5",
    "solid-js": "^1.9.11"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/js": "^10.0.1",
    "@iconify-json/material-symbols": "^1.2.63",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify/tailwind4": "^1.2.3",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.0",
    "daisyui": "^5.5.19",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "exifreader": "^4.37.0",
    "js-yaml": "^4.1.1",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "repomix": "^1.12.0",
    "tailwindcss": "^4.2.1",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
