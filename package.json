{
  "name": "reisinger-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter reisinger.pictures dev",
    "build": "pnpm --filter reisinger.pictures build",
    "editor": "concurrently \"tailwindcss -i ./packages/tools/editor/editor.tw.css -o ./packages/tools/editor/editor.css --watch\" \"http-server packages/tools -p 8080 -c-1 -o /editor/editor.html\"",
    "human-loop": "concurrently \"tailwindcss -i ./packages/tools/human-loop/human-loop.tw.css -o ./packages/tools/human-loop/human-loop.css --watch\" \"http-server packages/tools -p 8081 -c-1 -o /human-loop/human-loop.html\"",
    "merge:llm": "repomix",
    "build:reisinger.pictures": "pnpm --filter reisinger.pictures exec astro check && pnpm --filter reisinger.pictures build"
  },
  "devDependencies": {
    "repomix": "^1.13.1"
  }
}