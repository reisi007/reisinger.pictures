---
import type { InferGetStaticPropsType, PaginateFunction } from "astro";
import { getCollection, getEntry, render } from "astro:content";

import MinimalPage from "../components/pages/MinimalPage.astro";
import BaseHead from "../components/BaseHead.astro";
import PortfolioGrid from "../components/Portfolio.astro";
import ContentCard from "../components/ContentCard.astro";

export async function getStaticPaths({ paginate }: { paginate: PaginateFunction }) {
    const allPosts = (await getCollection("portfolio")).sort((a, b) => {
        const aTime = Math.max(a.data.date.valueOf(), a.data.updated?.valueOf() || 0);
        const bTime = Math.max(b.data.date.valueOf(), b.data.updated?.valueOf() || 0);
        return bTime - aTime;
    });
    return paginate(allPosts, { pageSize: 12 });
}

const { page } = Astro.props;

let ContentComponent = null;
let indexTitle = "Florian Reisinger Fotografie";

if (page.currentPage === 1) {
    // Lädt dynamisch die Root-Overview aus der Portfolio-Collection
    const indexEntry = await getEntry("portfolioOverviews", "index");
    if (indexEntry) {
        indexTitle = indexEntry.data.title || indexTitle;
        const rendered = await render(indexEntry);
        ContentComponent = rendered.Content;
    }
}
---
<MinimalPage>
    <BaseHead 
      title={page.currentPage === 1 ? indexTitle : `Portfolio - Seite ${page.currentPage}`}
      slot="head" 
    />
    
    {page.currentPage === 1 && (
      <>
        {ContentComponent && (
          <div class="prose max-w-none mb-10 text-base md:text-lg leading-relaxed text-base-content/90">
            <ContentComponent />
          </div>
        )}

        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 my-12 not-prose">
          <ContentCard 
            title="Beauty & Portrait" 
            imageName="beauty-sarah-home2025-portrait-rothaarig-intensiver-blick" 
            href="/shootings/beauty" 
            ctaLabel="Zu den Portraits" 
          />
          <ContentCard 
            title="Akt & Boudoir" 
            imageName="akt-boudoir-fine-art-gallery-b-03" 
            href="/shootings/akt" 
            ctaLabel="Zu den Aktbildern" 
          />
          <ContentCard 
            title="Pärchen & Liebe" 
            imageName="couples-schule1" 
            href="/shootings/couples" 
            ctaLabel="Pärchen-Bilder ansehen" 
          />
        </div>
      </>
    )}
    
    <div class="mt-16 border-t border-base-200 pt-10">
      <h2 class="text-3xl font-black mb-8 text-center">Neueste Einblicke aus dem Portfolio</h2>
      <PortfolioGrid page={page as any} />
    </div>
</MinimalPage>