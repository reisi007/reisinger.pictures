{
  "name": "reisinger.pictures",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "astro": "astro",
    "dev": "astro dev",
    "build": "PUBLIC_IMAGE_CDN_URL=https://images.reisinger.pictures astro check && PUBLIC_IMAGE_CDN_URL=https://images.reisinger.pictures astro build",
    "prebuild": "node ../../packages/tools/scripts/add-metadata.mjs && node ../../packages/tools/scripts/process-images.mjs",
    "postbuild": "node ../../packages/tools/scripts/check_links.mjs",
    "preview": "astro preview",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "publish": "pnpm run build",
    "postpublish": "./sync.sh",
    "merge:llm": "repomix",
    "editor": "concurrently \"tailwindcss -i ./editor/editor.tw.css -o ./editor/editor.css --watch\" \"http-server . -p 8080 -c-1 -o /editor/editor.html\"",
    "human-loop": "concurrently \"tailwindcss -i ./human-loop/human-loop.tw.css -o human-loop/human-loop.css --watch\" \"http-server . -p 8081 -c-1 -o /human-loop/human-loop.html\""
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/solid-js": "^7.0.1",
    "@tailwindcss/cli": "^4.3.3",
    "astro": "^7.1.2",
    "dayjs": "^1.11.21",
    "js-yaml": "^5.2.1",
    "jsdom": "^29.1.1",
    "photoswipe": "^5.4.4",
    "sharp": "^0.35.3",
    "solid-js": "^1.9.14"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint/js": "^10.0.1",
    "@iconify-json/material-symbols": "^1.2.86",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify/tailwind4": "^1.2.3",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.3",
    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.1",
    "concurrently": "^10.0.3",
    "daisyui": "^5.6.18",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^3.0.1",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-regexp": "^3.1.1",
    "eslint-plugin-simple-import-sort": "^14.0.0",
    "http-server": "^14.1.1",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "repomix": "^1.16.1",
    "tailwindcss": "^4.3.3",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.64.0"
  }
}
