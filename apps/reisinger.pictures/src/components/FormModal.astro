---
import Form from "@reisinger/shared/components/Form.astro";
---
<button
  onclick="document.getElementById('contact_modal').showModal();"
  class="tooltip tooltip-left tooltip-primary btn btn-primary btn-circle fixed bottom-6 right-6 z-[90] shadow-2xl h-16 w-16 flex items-center justify-center hover:scale-110 transition-transform group border-none"
  aria-label="Kontaktformular öffnen" 
  data-tip="Lass uns über dein Projekt sprechen!"
>
  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-7 group-hover:animate-pulse">
    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
  </svg>
</button>

<dialog id="contact_modal" class="modal modal-bottom sm:modal-middle z-[9999]">
  <div class="modal-box bg-base-100 max-w-lg">
    <form method="dialog">
      <button class="btn btn-sm btn-circle btn-ghost absolute right-3 top-3" aria-label="Schließen">
        <span class="icon-[mdi--close] size-5"></span>
      </button>
    </form>
    <div class="text-left not-prose pt-2">
      <h3 class="font-black text-2xl text-base-content mb-1">Projekt anfragen</h3>
      <Form />
    </div>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>Schließen</button>
  </form>
</dialog>

<script>
  document.addEventListener("astro:page-load", () => {
    const btn = document.getElementById('btn-projekt-anfragen');
    if (btn) {
      btn.addEventListener('click', () => {
        const modal = document.getElementById('contact_modal') as HTMLDialogElement;
        if (modal) modal.showModal();
      });
    }
  });
</script>
