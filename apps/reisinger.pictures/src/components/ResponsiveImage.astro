---
import type { ImageMetadata } from "astro";
import type { NumericBreakpoints } from "@reisinger/shared/utils/Breakpoints";
import { computeSizes, DEFAULT_IMAGE_SIZES, mergeBreakpoints } from "@reisinger/shared/utils/Breakpoints";
import { getImage } from "astro:assets";
import { getImage as getSourceImage } from "../images/slug-map";
import { getMetadataForImageSlug } from "./image.utils";
import { GALLERY_BREAKPOINTS, GalleryLayout } from "./GalleryLayout";
import { ResponsiveImageLoading } from "./ResponsiveImageLoading";
import type { ImageWithExifMeta } from "../types/image-metadata";

interface ImageWithMeta extends ImageMetadata, Partial<ImageWithExifMeta> {}

interface Props {
  name?: string,
  image?: ImageWithMeta | ImageMetadata,
  alt?: string,
  class?: string,
  height?: string,
  sizes?: string,
  widths?: number[],
  loading?: ResponsiveImageLoading,
  sizeModifiers?: Partial<NumericBreakpoints>,
  showInfo?: boolean
}

const {
  name,
  sizes,
  sizeModifiers,
  widths: widthsOverride,
  alt,
  loading = ResponsiveImageLoading.LAZY,
  class: classNames,
  showInfo = false,
  image: directImage
} = Astro.props;

const isDev = import.meta.env.MODE === "development";
const isBuild = import.meta.env.PROD;

const imageWithMeta = directImage as ImageWithMeta | undefined;

// Resolve image metadata instance (dev mode + direct-import fallback)
let image: ImageMetadata | undefined;
if (!isBuild || directImage) {
  if (directImage) {
    image = directImage;
  } else if (name) {
    const resolved = await getSourceImage(name);
    image = resolved.default;
  }
}

// Resolve native dimensions and CDN manifest data
let nativeWidth = 0;
let nativeHeight = 0;
let buildHash: string | undefined;
let buildVariants: number[] | undefined;

if (isBuild && name) {
  const { getManifestImage } = await import("../images/image-manifest");
  const mi = getManifestImage(name);
  if (mi) {
    nativeWidth = mi.width;
    nativeHeight = mi.height;
    buildHash = mi.hash;
    buildVariants = mi.variants;
  } else {
    throw new Error(
      `ResponsiveImage: "${name}" nicht in .imagedist/manifest.json gefunden. ` +
        `existiert der Slug in src/images/ oder src/content/?`
    );
  }
} else if (image) {
  nativeWidth = image.width;
  nativeHeight = image.height;
}

// --- Common metadata / EXIF ---
const data = imageWithMeta?.title
  ? { title: imageWithMeta.title, darkInvert: imageWithMeta.darkInvert ?? false, metadata: imageWithMeta.metadata ?? null }
  : name ? await getMetadataForImageSlug(name) : undefined;

const darkInvert = data?.darkInvert ?? false;
const resolvedAlt = alt ?? data?.title ?? "";
const computedSizes = sizes ?? computeSizes(mergeBreakpoints(GALLERY_BREAKPOINTS[GalleryLayout.Full], sizeModifiers));
const widths: number[] = (widthsOverride ?? DEFAULT_IMAGE_SIZES).filter(s => s <= nativeWidth);

const maxOptimizedWidth = widths[widths.length - 1] ?? nativeWidth;
const maxOptimizedHeight = maxOptimizedWidth * nativeHeight / nativeWidth;

const metadata = data?.metadata;
const equipment = metadata
  ? [metadata.camera, metadata.lens].filter(Boolean).join(" \u00b7 ")
  : undefined;

const isoLabel = metadata?.iso != null ? `ISO ${metadata.iso}` : undefined;
const exifCompact = metadata
  ? [metadata.focalLength, metadata.aperture, metadata.shutter && `${metadata.shutter}s`, isoLabel]
      .filter(Boolean).join(" \u00b7 ")
  : undefined;

const infoId = name ? `img-info-${name.replaceAll("/", "-")}` : imageWithMeta?.slug ? `img-info-${imageWithMeta.slug}` : undefined;

const captureDate = metadata?.captureDate ? new Date(metadata.captureDate).toISOString() : undefined;
const aspectRatioValue = `${nativeWidth}/${nativeHeight}`;

// --- Build src / srcset ---
let src: string;
let srcset: string;

if (isBuild && name && buildHash) {
  const { IMAGE_BASE_URL: cdnBase } = await import("../images/image-config");
  const prefix = `${cdnBase}/${buildHash.slice(0, 2)}/${buildHash}`;
  const cdnWidths = widths.filter(w => buildVariants!.includes(w));
  const effectiveWidths = cdnWidths.length > 0 ? cdnWidths : [buildVariants![0]];
  src = `${prefix}_${effectiveWidths[effectiveWidths.length - 1]}.webp`;
  srcset = effectiveWidths.map(w => `${prefix}_${w}.webp ${w}w`).join(", ");
} else if (isBuild && name && !buildHash) {
  throw new Error(`ResponsiveImage: "${name}" nicht in .imagedist/manifest.json gefunden. existsiert der Slug in src/images/ oder src/content/portfolio/?`);
} else {
  const imageVariants = await Promise.all(
    widths.map(w => getImage({ src: image!, format: "webp", width: w, quality: "mid" }))
  );
  src = imageVariants[imageVariants.length - 1].src;
  srcset = imageVariants.map((v, i) => `${v.src} ${widths[i]}w`).join(", ");
}

const darkClass = darkInvert ? "dark:invert" : "";
const imgClass = [classNames, darkClass].filter(Boolean).join(" ") || undefined;
---

{showInfo && (name || imageWithMeta?.slug) ? (
  <div class="relative mx-auto overflow-hidden max-w-full max-h-full" style={`aspect-ratio: ${aspectRatioValue};`}>
    <img
      src={src}
      srcset={srcset}
      sizes={computedSizes}
      loading={loading}
      class={[imgClass, "w-full h-full object-contain"].filter(Boolean).join(" ")}
      alt={resolvedAlt}
      data-pswp-width={maxOptimizedWidth}
      data-pswp-height={maxOptimizedHeight}
      data-name={isDev ? (name ?? imageWithMeta?.slug) : undefined}
      data-exif-camera={metadata?.camera}
      data-exif-lens={metadata?.lens}
      data-exif-focal={metadata?.focalLength}
      data-exif-aperture={metadata?.aperture}
      data-exif-shutter={metadata?.shutter}
      data-exif-iso={metadata?.iso}
      data-exif-date={captureDate}
      decoding="async"
      width={maxOptimizedWidth}
      height={maxOptimizedHeight}
      style="display:block"
    />
    <div class="info-overlay group absolute inset-0" onclick="event.stopPropagation()">
      <input type="checkbox" id={infoId} class="peer sr-only" />
      <label
        for={infoId}
        class="absolute top-3 right-3 z-10 size-9 flex items-center justify-center rounded-full bg-primary/70 text-primary-content ring-1 ring-primary-content/30 opacity-90 hover:opacity-100 peer-checked:opacity-100 peer-focus-visible:opacity-100 cursor-pointer transition-all"
        aria-label="Bildinformationen ein-/ausblenden"
        onclick="event.stopPropagation()"
      >
        <span class="icon-[mdi--information-outline] size-5" />
      </label>
      <div class="info-box absolute inset-x-0 bottom-0 bg-base-300/90 backdrop-blur p-4 text-sm opacity-0 peer-checked:opacity-100 transition-opacity pointer-events-none peer-checked:pointer-events-auto">
        <p class="text-base-content leading-snug m-0">{resolvedAlt}</p>
        {equipment && <p class="text-base-content/80 m-0 mt-1">{equipment}</p>}
        {exifCompact && <p class="text-base-content/70 m-0 mt-0.5">{exifCompact}</p>}
      </div>
    </div>
  </div>
) : (
  <img
    src={src}
    srcset={srcset}
    sizes={computedSizes}
    loading={loading}
    class={imgClass}
    alt={resolvedAlt}
    data-pswp-width={maxOptimizedWidth}
    data-pswp-height={maxOptimizedHeight}
      data-name={isDev ? name : undefined}
      data-exif-camera={metadata?.camera}
      data-exif-lens={metadata?.lens}
      data-exif-focal={metadata?.focalLength}
      data-exif-aperture={metadata?.aperture}
      data-exif-shutter={metadata?.shutter}
      data-exif-iso={metadata?.iso}
      data-exif-date={captureDate}
      decoding="async"
      width={maxOptimizedWidth}
      height={maxOptimizedHeight}
  />
)}
