---
import { absoluteLink } from "@reisinger/shared/utils";
import { getImage } from "astro:assets";

import { getImage as getImageByName } from "../images/Images";
import type { Organization, Person, SchemaCreationFunction } from "./SchemaOrg";

const url = Astro.url;


function formatDate(date?: Date): string | undefined {
  if (date === undefined) return undefined;
  const year = date.getFullYear();

  // getMonth() is zero-based (0-11), so we add 1.
  const month = date.getMonth() + 1;

  const day = date.getDate();

  // Pad month and day with a leading zero if they are single-digit.
  const paddedMonth = String(month).padStart(2, "0");
  const paddedDay = String(day).padStart(2, "0");

  return `${year}-${paddedMonth}-${paddedDay}`;
}

export interface Props {
  createData: SchemaCreationFunction;
}

const { createData } = Astro.props;

const logoInfo = await getImage({
  src: getImageByName("logo"),
  format: "webp"
});

const me: Person = {
  "@type": "Person",
  name: "Florian Reisinger"
};

const organisation: Organization = {
  "@type": "Organization",
  name: "Fotograf Florian Reisinger",
  url: Astro.site?.toString(),
  logo: absoluteLink(Astro.url, logoInfo.src),
  address: {
    "@type": "PostalAddress",
    addressCountry: "AT",
    addressLocality: "Linz",
    postalCode: "4020",
    streetAddress: "Robert-Stolz-Straße 8"
  }
};

const data = createData(organisation, me, e => formatDate(e), url.toString());
const json = JSON.stringify(data);

const siteUrl = Astro.site?.toString();

// Top-level LocalBusiness node emitted on every page for rich business panels.
const business = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  name: "Fotograf Florian Reisinger",
  description:
    "Professionelle Portrait-, Beauty-, Akt-, Boudoir- und Paar-Shootings in Linz. Business-Portraits und Personal Branding für Selbstständige und Führungskräfte. Event- und Sportfotografie mit eigenem Presse-Portal.",
  url: siteUrl,
  image: absoluteLink(Astro.url, logoInfo.src),
  telephone: "+43 670 201 77 10",
  priceRange: "\u20ac\u20ac",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Robert-Stolz-Stra\u00dfe 8",
    addressLocality: "Linz",
    postalCode: "4020",
    addressCountry: "AT"
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 48.3069,
    longitude: 14.2858
  },
  areaServed: { "@type": "City", name: "Linz" },
  founder: { "@type": "Person", name: "Florian Reisinger" },
  sameAs: ["https://reisinger.pictures"],
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Fotografie-Dienstleistungen",
    itemListElement: [
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Personal Branding & Business-Portraits",
          description: "Corporate Portraits für Selbstständige, Führungskräfte und Speaker. 2h Shooting inkl. Vorbesprechung, 12 Indoor-/24 Outdoor-Bilder, private Online-Galerie, umfassendes Nutzungsrecht.",
          url: siteUrl ? `${siteUrl}personal-branding/` : undefined,
          areaServed: { "@type": "City", name: "Linz" }
        }
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Event- & PR-Fotografie",
          description: "Professionelle Event-Dokumentation mit Presse-Portal inkl. Live-Delivery, IPTC-Metadaten und Batch-Download für Redaktionen.",
          url: siteUrl ? `${siteUrl}eventfotografie/` : undefined,
          areaServed: { "@type": "City", name: "Linz" }
        }
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Portrait & Beauty-Shootings",
          description: "Individuelle Beauty- und Portrait-Shootings in Linz. Studio indoor oder Outdoor mit natürlichem Licht.",
          url: siteUrl ? `${siteUrl}shootings/beauty/` : undefined,
          areaServed: { "@type": "City", name: "Linz" }
        }
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Sportfotografie",
          description: "Professionelle Sportfotografie aus der österreichischen Bundesliga und internationalen Bewerben.",
          url: siteUrl ? `${siteUrl}shootings/sport/` : undefined,
          areaServed: { "@type": "City", name: "Linz" }
        }
      }
    ]
  },
  openingHoursSpecification: {
    "@type": "OpeningHoursSpecification",
    dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
    opens: "09:00",
    closes: "18:00"
  }
};
const businessJson = JSON.stringify(business);
---

<script type="application/ld+json" is:inline set:html={businessJson} />
<script type="application/ld+json" is:inline set:html={json} />
