---
import { absoluteLink } from "@reisinger/shared/utils";
import { getImage } from "astro:assets";

import { getImage as getImageByName } from "../images/slug-map";
import { getMetadataForImageSlug } from "./image.utils";

interface Props {
  /** Image slug to use as social preview. Falls back to "me" (portrait) when omitted. */
  name?: string;
}

const { name } = Astro.props;

// Fall back to the photographer portrait so every page has a social preview image.
const resolvedName = name ?? "me";

const imageInfo = await getImage({
  src: getImageByName(resolvedName),
  format: "webp",
  width: 1200,
  height: 630,
  fit: "cover"
});

const alt = (await getMetadataForImageSlug(resolvedName))?.title;

const { src, options } = imageInfo;
const fullSrc = absoluteLink(Astro.url, src);
const { width, height, format } = options;
---
<meta property="og:image" content={fullSrc} />
<meta property="og:image:width" content={`${width}`} />
<meta property="og:image:height" content={`${height}`} />
<meta property="og:image:type" content={format} />
<meta name="twitter:image" content={fullSrc} />
<meta name="twitter:image:alt" content={alt} />
<meta name="twitter:card" content="summary_large_image" />
