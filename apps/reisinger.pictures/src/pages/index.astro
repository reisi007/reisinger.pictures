---
import { Image } from "astro:assets";
import BaseHead from "../components/BaseHead.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { contactLink } from "../utils/links";

const images = import.meta.glob<{ default: ImageMetadata }>('/src/images/*.{jpeg,jpg,png,gif,webp}');
const heroImgSrc = (await images['/src/images/hero.jpg']()).default;

const title = "Florian Reisinger | Business & Event Fotografie Linz";
const description = "Professionelle Personal Branding Portraits und Event-Fotografie mit eigenem Presse-Portal. Transparente Fixpreise ab 210€.";
---
<BaseLayout>
  <BaseHead slot="head" title={title} description={description} />

  <main class="flex-grow">
    <section class="h-[85vh] min-h-[550px] relative overflow-hidden bg-base-300">
      <Image
        src={heroImgSrc}
        alt="Florian Reisinger Business Fotografie"
        class="absolute inset-0 w-full h-full object-cover object-center"
        widths={[720, 1280, 1920]}
        sizes="100vw"
      />
      <div class="absolute inset-0 bg-base-300/40"></div>

      <div class="absolute inset-0 flex flex-col items-center justify-center text-center px-6">
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-black text-base-100 tracking-tight leading-tight">
          Persönlichkeit<span class="hidden md:inline"> trifft</span><br class="md:hidden" /> Professionalität
        </h1>
        <p class="text-lg md:text-2xl text-base-100/80 mt-4 md:mt-6 max-w-2xl">
          Corporate Portraits und Event-Fotografie, die dein Business ins beste Licht rücken.
        </p>
        <a href={contactLink('BUSINESS')} class="btn btn-primary btn-lg mt-8 shadow-lg border-none text-lg px-8">
          Projekt anfragen
        </a>
      </div>
    </section>

    <section class="max-w-5xl mx-auto px-6 py-16 md:py-24">
      <h2 class="text-3xl md:text-4xl font-black text-center text-base-content mb-12">Meine Leistungen</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-base-200 rounded-2xl p-8 flex flex-col h-full">
          <span class="icon-[mdi--account-star] size-10 text-primary mb-4"></span>
          <h3 class="text-2xl font-black text-base-content mb-3">Personal Branding</h3>
          <p class="text-base-content/70 mb-6 flex-grow">
            Corporate Portraits mit Wow-Effekt. Kein 0815-Bewerbungsfoto, sondern Charakterbilder, die deine Persönlichkeit transportieren – ob als Selbstständiger, Führungskraft oder Speaker.
          </p>
          <a href="/personal-branding" class="btn btn-outline btn-primary mt-auto border-2">Mehr erfahren</a>
        </div>

        <div class="bg-base-200 rounded-2xl p-8 flex flex-col h-full">
          <span class="icon-[mdi--camera-party-mode] size-10 text-primary mb-4"></span>
          <h3 class="text-2xl font-black text-base-content mb-3">Event & PR</h3>
          <p class="text-base-content/70 mb-6 flex-grow">
            Pressebilder, Firmenevents, Galas. Mit meinem eigenen Presse-Portal bekommst du fertig betextete Bilder in Echtzeit – kein Warten, keine WeTransfer-Links.
          </p>
          <a href="/eventfotografie" class="btn btn-outline btn-primary mt-auto border-2">Mehr erfahren</a>
        </div>
      </div>
    </section>

    <section class="bg-base-200 py-16 md:py-24">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-black text-base-content mb-6">Transparente Preisgestaltung</h2>

        <div class="bg-base-100 rounded-2xl p-8 md:p-10 shadow-sm">
          <p class="text-5xl md:text-6xl font-black text-primary mb-2">
            ab 210<span class="text-2xl text-base-content/50">€</span>
          </p>
          <p class="text-base-content/60 text-lg mb-8">2 Stunden Shooting inkl. Setup & Vorbesprechung</p>

          <div class="w-16 h-0.5 bg-primary/30 mx-auto mb-8"></div>

          <div class="flex flex-col gap-3 text-left max-w-md mx-auto">
            <p class="flex items-start gap-3 text-base-content/80">
              <span class="text-primary mt-0.5 shrink-0">✓</span>12 Indoor / 24 Outdoor bearbeitete Bilder
            </p>
            <p class="flex items-start gap-3 text-base-content/80">
              <span class="text-primary mt-0.5 shrink-0">✓</span>Private Online-Galerie im Reisinger Foto Portal
            </p>
            <p class="flex items-start gap-3 text-base-content/80">
              <span class="text-primary mt-0.5 shrink-0">✓</span>Umfassendes Nutzungsrecht für dein Business
            </p>
          </div>

          <a href={contactLink('BUSINESS')} class="btn btn-primary btn-lg mt-8 shadow-lg border-none">
            Jetzt unverbindlich anfragen
          </a>
        </div>
      </div>
    </section>

    <section class="max-w-5xl mx-auto px-6 py-16 md:py-24">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
        <div class="flex flex-col items-center">
          <span class="icon-[mdi--handshake] size-12 text-primary mb-4"></span>
          <h3 class="text-xl font-black text-base-content mb-2">Persönlich</h3>
          <p class="text-base-content/70">Direkte Zusammenarbeit ohne Mittelsmann. Dein Ansprechpartner von Anfang bis Ende.</p>
        </div>
        <div class="flex flex-col items-center">
          <span class="icon-[mdi--cloud-upload] size-12 text-primary mb-4"></span>
          <h3 class="text-xl font-black text-base-content mb-2">Direkt</h3>
          <p class="text-base-content/70">Bilder noch am Event-Tag via Presse-Portal. Ready to publish, mit IPTC-Metadaten.</p>
        </div>
        <div class="flex flex-col items-center">
          <span class="icon-[mdi--cash-check] size-12 text-primary mb-4"></span>
          <h3 class="text-xl font-black text-base-content mb-2">Transparent</h3>
          <p class="text-base-content/70">Klare Fixpreise, keine versteckten Kosten. Was du siehst, ist was du bekommst.</p>
        </div>
      </div>
    </section>

    <section class="bg-base-200 py-16 md:py-24">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-black text-base-content mb-6">Über mich</h2>
        <p class="text-base-content/70 text-lg leading-relaxed max-w-2xl mx-auto">
          Ich bin Florian Reisinger, Berufsfotograf aus Linz. Mein Fokus liegt auf ausdrucksstarken Business-Portraits und professioneller Event-Dokumentation. Mit meinem selbst entwickelten Presse-Portal liefere ich Bilder schneller und strukturierter als klassische Agenturen – direkt, persönlich, auf den Punkt.
        </p>
      </div>
    </section>

    <section class="max-w-5xl mx-auto px-6 py-16 md:py-24 text-center">
      <p class="text-xl md:text-2xl text-base-content/80 mb-6">
        Bereit für Bilder, die dein Business voranbringen?
      </p>
      <a href={contactLink('BUSINESS')} class="btn btn-primary btn-lg shadow-lg border-none text-lg px-8">
        Projekt anfragen
      </a>
    </section>
  </main>
</BaseLayout>
