---
import type { InferGetStaticPropsType } from "astro";
import { getCollection } from "astro:content";

import BaseHead from "../../components/BaseHead.astro";
import MinimalPage from "../../components/pages/MinimalPage.astro";
import ReviewCard from "../../components/ReviewCard.astro";
import SocialImage from "../../components/SocialImage.astro";
import { filterInvalidImageName } from "../../images/slug-map";

export async function getStaticPaths() {
  return (await getCollection("testimonials")).map(r => ({
    params: { slug: r.id },
    props: r
  }));

}

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const props = Astro.props;
const { data, id: slug, body } = props;
const { name, rating, date, large } = data;
const title = `Eine ehrliche Bewertung von ${name}`;
const socialImage = filterInvalidImageName(large ?? `${slug}-large`);

// Extract plain-text review body from the raw markdown for structured data.
const reviewBody = (body ?? "")
  .replace(/[#*_`>~[\]()!]/g, "")
  .replace(/\s+/g, " ")
  .trim()
  .replace(/&/g, "&amp;")
  .replace(/</g, "&lt;")
  .replace(/>/g, "&gt;")
  .replace(/"/g, "&quot;")
  .replace(/'/g, "&#39;");

// Map percentage rating (0-100) to a 5-star scale for Schema.org.
const starRating = rating !== undefined ? (rating / 20).toFixed(1) : undefined;

const businessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Fotografie by Florian Reisinger",
  serviceType: "Photography",
  review: {
    "@type": "Review",
    reviewBody,
    name: title,
    author: { "@type": "Person", name },
    datePublished: date.toISOString().split("T")[0],
    reviewRating: starRating ? {
      "@type": "Rating",
      ratingValue: starRating,
      bestRating: "5"
    } : undefined
  }
};
const reviewJson = JSON.stringify(businessSchema);
---
<MinimalPage>
  <BaseHead title={title} author={name} slot="head">
    <SocialImage name={socialImage} />
  </BaseHead>
  <div class="mb-6 mt-2">
    <ReviewCard {...props} />
  </div>
</MinimalPage>
<script type="application/ld+json" is:inline set:html={reviewJson} />