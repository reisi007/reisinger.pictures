---
import type { NumericBreakpoints } from "@reisinger/shared/utils/Breakpoints";
import { computeSizes, DEFAULT_IMAGE_SIZES, mergeBreakpoints } from "@reisinger/shared/utils/Breakpoints";
import { getImage as getOptimizedImage } from "astro:assets";

import { getImage as getSourceImage } from "../images/Images";
import { GALLERY_BREAKPOINTS, GalleryLayout } from "./GalleryLayout";
import { getMetadataForImageSlug } from "./image.utils";
import { ResponsiveImageLoading } from "./ResponsiveImageLoading";

interface Props {
  name: string,
  alt?: string,
  class?: string,
  height?: string,
  sizes?: string,
  widths?: number[],
  loading?: ResponsiveImageLoading,
  sizeModifiers?: Partial<NumericBreakpoints>
}

const {
  name,
  sizes,
  sizeModifiers,
  widths: widthsOverride,
  alt = "",
  loading = ResponsiveImageLoading.LAZY,
  class: classNames
} = Astro.props;

const isDevMode = import.meta.env.MODE === "development";
const image = (await getSourceImage(name)).default;
const data = await getMetadataForImageSlug(name);
const darkInvert = data?.darkInvert ?? false;
const computedSizes = sizes ?? computeSizes(mergeBreakpoints(GALLERY_BREAKPOINTS[GalleryLayout.Full], sizeModifiers));
const widths: number[] = (widthsOverride ?? DEFAULT_IMAGE_SIZES).filter(s => s <= image.width);

const maxOptimizedWidth = widths[widths.length - 1];
const maxOptimizedHeight = maxOptimizedWidth * image.height / image.width;

const avif = await getOptimizedImage({ src: image, format: "avif", widths, sizes: computedSizes, quality: "med" });
const webp = await getOptimizedImage({ src: image, format: "webp", widths, sizes: computedSizes, quality: "med" });
---
<picture>
  <source srcset={avif.srcSet.attribute} type="image/avif" sizes={computedSizes}>
  <img
    src={webp.src}
    srcset={webp.srcSet.attribute}
    sizes={computedSizes}
    alt={alt}
    loading={loading}
    decoding="async"
    width={webp.attributes.width}
    height={webp.attributes.height}
    class:list={[{ "dark:invert": darkInvert }, classNames]}
    data-pswp-width={maxOptimizedWidth}
    data-pswp-height={maxOptimizedHeight}
    data-name={isDevMode ? name : undefined}
  />
</picture>
