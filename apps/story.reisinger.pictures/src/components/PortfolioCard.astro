---
import type { NumericBreakpoints } from "@reisinger/shared/utils/Breakpoints";
import { type CollectionEntry } from "astro:content";

import ContentCard from "./ContentCard.astro";

interface Props {
  post: CollectionEntry<"portfolio">;
  imageSizeModifiers?: Partial<NumericBreakpoints>;
  class?: string;
}

const { post, imageSizeModifiers, class: clazz } = Astro.props;
---
<ContentCard
  href={`/portfolio/${post.id}/`}
  imageName={post.data.heroImage}
  title={post.data.title}
  date={post.data.updated ?? post.data.date}
  imageSizeModifiers={imageSizeModifiers}
  class={clazz}
/>