---
import ResponsiveImage from './ResponsiveImage.astro';
import * as navigation from '../data/Menue';
import type { NavItem } from '../data/Menue';

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/' && currentPath === '/') return true;
  if (href !== '/' && currentPath.startsWith(href)) return true;
  return false;
}

function isItemActive(item: NavItem): boolean {
  if ('href' in item) return isActive(item.href);
  return item.subItems.some(sub => isActive(sub.href));
}

const linkSections = [
  { label: "Business & Presse", links: navigation.businessLinks, b2b: true },
  { label: "Privat & Emotion", links: navigation.privateLinks, b2b: false },
];
---

<header class="w-full bg-base-100/90 backdrop-blur-sm sticky top-0 z-50 border-b border-base-200 mb-4">
  <div class="navbar container mx-auto px-4 sm:px-0">
    <div class="navbar-start">
      <a href="/" class="flex items-center gap-3 no-underline group">
        <ResponsiveImage
          name="me"
          alt="Florian Reisinger Pictures"
          class="size-10 rounded-full object-cover group-hover:ring-2 ring-primary transition-all shadow"
          sizes="40px"
          widths={[40]}
        />
        <div class="flex flex-col leading-tight">
          <span class="text-xl font-bold text-primary group-hover:text-base-content transition-colors">Reisinger</span>
          <span class="text-[0.65rem] uppercase tracking-widest text-base-content/70">Pictures</span>
        </div>
      </a>
    </div>

    <div class="navbar-center hidden lg:flex">
      <ul class="menu menu-horizontal px-1 gap-1 text-base font-medium z-50">
        {linkSections.map(section => (
          <li>
            <div class="dropdown dropdown-hover py-2">
              <div tabindex="0" role="button" class={section.links.some(isItemActive) ? "text-primary font-semibold" : ""}>
                {section.label} <span class="mdi--chevron-down opacity-50 ml-1"></span>
              </div>
              <ul tabindex="0" class="dropdown-content menu bg-base-100 rounded-box z-[1] w-52 p-2 shadow-xl border border-base-200 mt-0 top-full">
                {section.links.map(item => (
                  <li>
                    {'subItems' in item ? (
                      <details>
                        <summary class={item.subItems.some(sub => isActive(sub.href)) ? "text-primary font-semibold" : ""}>{item.label}</summary>
                        <ul class="p-2 bg-base-100 shadow-sm border border-base-200 rounded-box">
                          {item.subItems.map(sub => (
                            <li>
                              <a href={sub.href} target={sub.external ? "_blank" : undefined} rel={sub.external ? "noopener noreferrer" : undefined} class={isActive(sub.href) ? "active" : ""}>
                                {sub.label} {sub.external && <span class="mdi--open-in-new text-xs opacity-50"></span>}
                              </a>
                            </li>
                          ))}
                        </ul>
                      </details>
                    ) : (
                      <a href={item.href} target={item.external ? "_blank" : undefined} rel={item.external ? "noopener noreferrer" : undefined} class={isActive(item.href) ? "active" : ""}>
                        {item.label} {item.external && <span class="mdi--open-in-new text-xs opacity-50"></span>}
                      </a>
                    )}
                  </li>
                ))}
              </ul>
            </div>
          </li>
        ))}
        {navigation.infoLinks.map(link => {
          if ('href' in link) {
            return (
              <li>
                <a href={link.href} target={link.external ? "_blank" : undefined} rel={link.external ? "noopener noreferrer" : undefined} class={isActive(link.href) ? "text-primary font-semibold" : ""}>
                  {link.label} {link.external && <span class="mdi--open-in-new text-xs opacity-50"></span>}
                </a>
              </li>
            );
          }
        })}
      </ul>
    </div>

    <div class="navbar-end gap-2">
      <button onclick="document.getElementById('contact_modal').showModal()" class="btn btn-primary btn-sm md:btn-md shadow-md hidden sm:flex">
        Anfrage
      </button>
      <button id="mobile-menu-btn" aria-label="open menu" class="btn btn-ghost btn-circle lg:hidden">
        <span class="mdi--menu text-2xl"></span>
      </button>
    </div>
  </div>
</header>

{/* --- FULL WIDTH MOBILE MENU OVERLAY --- */}
<div id="mobile-menu-overlay" class="fixed inset-0 bg-base-100 z-100 hidden opacity-0 transition-opacity duration-300">
  <div class="flex justify-between items-center bg-base-100 border-b border-base-200 p-4 sticky top-0 z-10 w-full min-h-16">
    <a href="/" class="flex items-center gap-3 no-underline">
      <ResponsiveImage
        name="me"
        alt="Florian Reisinger Pictures"
        class="size-10 rounded-full object-cover shadow"
        sizes="40px"
        widths={[40]}
      />
      <span class="text-xl font-bold text-primary">Reisinger</span>
    </a>
    <button id="mobile-menu-close" aria-label="close menu" class="btn btn-ghost btn-circle">
      <span class="mdi--close text-2xl"></span>
    </button>
  </div>

  <div class="flex-grow overflow-y-auto p-4 flex flex-col pb-24">
    <ul class="menu menu-lg w-full p-0 gap-4">
      {linkSections.map((section, idx) => (
        <li>
          <details name="mobile-main-accordion" open={section.links.some(isItemActive) || (!linkSections.some(s => s.links.some(isItemActive)) && idx === 1)}>
            <summary class="text-sm uppercase tracking-widest text-base-content/50 font-bold mb-1">
              {section.label}
            </summary>
            <ul class="pl-4 border-l-2 border-base-200 ml-2 mt-2 gap-1">
              {section.links.map(item => (
                <li>
                  {'subItems' in item ? (
                    <details open={item.subItems.some(sub => isActive(sub.href))}>
                      <summary class={item.subItems.some(sub => isActive(sub.href)) ? "text-primary font-bold" : ""}>{item.label}</summary>
                      <ul class="pl-4 border-l-2 border-base-200 ml-2 mt-2 gap-1">
                        {item.subItems.map(sub => (
                          <li>
                            <a href={sub.href} target={sub.external ? "_blank" : undefined} rel={sub.external ? "noopener noreferrer" : undefined} class={isActive(sub.href) ? "active font-bold text-primary" : ""}>
                              {sub.label} {sub.external && <span class="mdi--open-in-new text-base opacity-50"></span>}
                            </a>
                          </li>
                        ))}
                      </ul>
                    </details>
                  ) : (
                    <a href={item.href} target={item.external ? "_blank" : undefined} rel={item.external ? "noopener noreferrer" : undefined} class={isActive(item.href) ? "active font-bold text-primary" : ""}>
                      {item.label} {item.external && <span class="mdi--open-in-new text-base opacity-50"></span>}
                    </a>
                  )}
                </li>
              ))}
            </ul>
          </details>
        </li>
      ))}
    </ul>

    <div class="mt-auto pt-8 border-t border-base-200">
      <ul class="menu menu-md gap-1 flex-row flex-wrap justify-center w-full p-0">
        {navigation.infoLinks.map(link => {
          if ('href' in link) {
            return (
              <li>
                <a href={link.href} target={link.external ? "_blank" : undefined} rel={link.external ? "noopener noreferrer" : undefined} class={isActive(link.href) ? "text-primary font-bold" : ""}>
                  {link.label} {link.external && <span class="mdi--open-in-new text-xs opacity-50"></span>}
                </a>
              </li>
            );
          }
        })}
      </ul>
      <div class="mt-6 text-center px-4">
        <button onclick="document.getElementById('contact_modal').showModal(); document.getElementById('mobile-menu-close').click();" class="btn btn-primary btn-block shadow-md">
          <span class="mdi--message-text text-xl"></span> Jetzt anfragen
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const btnOpen = document.getElementById('mobile-menu-btn');
    const btnClose = document.getElementById('mobile-menu-close');
    const overlay = document.getElementById('mobile-menu-overlay');

    if (btnOpen && btnClose && overlay) {
      const openMenu = () => {
        overlay.classList.remove('hidden');
        overlay.classList.add('flex', 'flex-col');
        void overlay.offsetWidth;
        overlay.classList.remove('opacity-0');
        overlay.classList.add('opacity-100');
        document.body.style.overflow = 'hidden';
      };

      const closeMenu = () => {
        overlay.classList.remove('opacity-100');
        overlay.classList.add('opacity-0');
        document.body.style.overflow = '';
        setTimeout(() => {
          overlay.classList.remove('flex', 'flex-col');
          overlay.classList.add('hidden');
        }, 300);
      };

      btnOpen.addEventListener('click', openMenu);
      btnClose.addEventListener('click', closeMenu);

      const links = overlay.querySelectorAll('a');
      links.forEach(link => { link.addEventListener('click', closeMenu); });
    }

    const dropdownLinks = document.querySelectorAll('header .navbar-center details a');
    dropdownLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        let el = e.target as HTMLElement | null;
        while (el) {
          if (el.tagName === 'DETAILS') el.removeAttribute('open');
          el = el.parentElement;
        }
      });
    });
  });
</script>