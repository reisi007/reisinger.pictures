---
import { calculatePackagePrice } from "../content/pricing";
import { formatPsychologicalPrice } from "../utils";

// Initiale Werte (Startpunkte auf den Slidern)
const initialDuration = 90;
const initialImages = 10;

// Initiale Preisberechnung (Normalpreis)
const initialPrice = calculatePackagePrice(initialDuration, initialImages);
const formattedInitialPrice = formatPsychologicalPrice(initialPrice);

// ==========================================
// TEXT-VERWALTUNG (Einfach hier anpassen!)
// ==========================================

// Features, die IMMER angezeigt werden
const baseFeatures = [
  "Volle Flexibilität und Kostenkontrolle"
];

// Features NUR FÜR DEN NORMALPREIS
const standardFeatures = [
  "Redaktionelle kommerzielle Nutzungsrechte inklusive"
];

// Features NUR FÜR DEN RABATT
const discountFeatures = [
  "Private Nutzungsrechte inklusive"
];

// Footer-Hinweise NUR FÜR DEN NORMALPREIS
const standardFooters = [
  "Wir shooten, bis du dich wohlfühlst",
  "Höchste Diskretion & Vertrauen inklusive"
];

// Footer-Hinweise NUR FÜR DEN RABATT
const discountFooters = [
  "Voraussetzung: Veröffentlichung der Bilder",
  "Gilt nur für Beauty, Pärchen & Akt"
];
---

<custom-pricing-builder
  class="card shadow-xl relative overflow-hidden bg-base-100 text-base-content border border-base-300 h-full transition-transform hover:-translate-y-1 md:col-span-2 block"
>
  <div class="card-body p-8 flex flex-col h-full">
    <div class="text-center mb-6">
      <h2 class="text-3xl font-black uppercase tracking-wide mb-2 text-primary">
        Dein individuelles Paket
      </h2>
      <p class="opacity-80 text-sm font-medium">
        Stelle dir dein eigenes Shooting exakt nach deinen Bedürfnissen zusammen.
      </p>
    </div>

    <div class="divider opacity-20 my-0"></div>

    <div class="flex flex-col items-center justify-center my-6 min-h-[6rem]">
      <span class="original-price-display text-lg line-through text-primary opacity-40 decoration-1 hidden mb-1">
        {formattedInitialPrice}
      </span>
      <span class="price-display text-5xl font-black text-center tracking-tight text-base-content">
        {formattedInitialPrice}
      </span>
    </div>

    <div class="space-y-6 mb-2 w-full max-w-sm mx-auto">
      <div>
        <label class="label pb-1">
          <span class="duration-label label-text font-bold">Shooting-Zeit: {initialDuration} Minuten</span>
        </label>
        <input
          type="range"
          min="60"
          max="480"
          step="30"
          value={initialDuration}
          class="duration-slider range range-primary range-sm"
        />
        <div class="w-full flex justify-between text-xs px-1 mt-1 opacity-50 font-medium">
          <span>1 Std</span>
          <span>8 Std</span>
        </div>
      </div>

      <div>
        <label class="label pb-1">
          <span class="images-label label-text font-bold">Bearbeitete Bilder: {initialImages} Stück</span>
        </label>
        <input
          type="range"
          min="3"
          max="120"
          step="1"
          value={initialImages}
          class="images-slider range range-primary range-sm"
        />
        <div class="w-full flex justify-between text-xs px-1 mt-1 opacity-50 font-medium">
          <span>3</span>
          <span>120</span>
        </div>
      </div>

      <div class="form-control w-full mt-4">
        <label class="cursor-pointer label">
          <input type="checkbox" class="discount-checkbox toggle toggle-sm toggle-primary" />
          <span class="label-text font-bold">Ich bin zwischen 18 und 25 Jahre alt</span>
        </label>
      </div>
    </div>

    <ul class="space-y-3 mt-6">
      {/* 1. Basis-Features (immer sichtbar) */}
      {baseFeatures.map((feature) => (
        <li class="flex items-start gap-3">
          <span class="size-6 shrink-0 rounded-full flex items-center justify-center text-xs mt-0.5 bg-primary/10 text-primary">
            <span class="mdi--check"></span>
          </span>
          <span class="font-medium text-sm leading-6">{feature}</span>
        </li>
      ))}

      {/* 2. Normalpreis-Features */}
      {standardFeatures.map((feature) => (
        <li class="feature-standard flex items-start gap-3">
          <span class="size-6 shrink-0 rounded-full flex items-center justify-center text-xs mt-0.5 bg-primary/10 text-primary">
            <span class="mdi--check"></span>
          </span>
          <span class="font-medium text-sm leading-6">{feature}</span>
        </li>
      ))}

      {/* 3. Rabatt-Features (initial versteckt) */}
      {discountFeatures.map((feature) => (
        <li class="feature-discount hidden items-start gap-3">
          <span class="size-6 shrink-0 rounded-full flex items-center justify-center text-xs mt-0.5 bg-primary/10 text-primary">
            <span class="mdi--check"></span>
          </span>
          <span class="font-medium text-sm leading-6">{feature}</span>
        </li>
      ))}
    </ul>

    <div class="mt-6 mb-2 gap-y-2 flex flex-col">
      {/* 1. Normalpreis-Footer */}
      {standardFooters.map((footer) => (
        <div class="footer-standard border-base-300 border grid grid-cols-8 gap-x-2 items-center text-xs font-bold opacity-70 py-2 rounded-lg justify-center px-3">
          <span class="mdi--information-outline text-lg text-center"></span>
          <span class="col-span-7">{footer}</span>
        </div>
      ))}

      {/* 2. Rabatt-Footer (initial versteckt) */}
      {discountFooters.map((footer) => (
        <div class="footer-discount border-base-300 border hidden grid-cols-8 gap-x-2 items-center text-xs font-bold opacity-70 py-2 rounded-lg justify-center px-3">
          <span class="mdi--information-outline text-lg text-center"></span>
          <span class="col-span-7">{footer}</span>
        </div>
      ))}
    </div>

    <div class="card-actions mt-auto pt-4 border-t border-base-300 border-opacity-50">
      <a href="#kontakt" class="btn btn-block shadow-lg border-0 btn-primary">
        Individuelles Paket anfragen
      </a>
    </div>
  </div>
</custom-pricing-builder>

<script>
  import { calculatePackagePrice } from "../content/pricing";
  import { formatPsychologicalPrice } from "../utils";

  class CustomPricingBuilder extends HTMLElement {
    connectedCallback() {
      const durationSlider = this.querySelector('.duration-slider') as HTMLInputElement;
      const imagesSlider = this.querySelector('.images-slider') as HTMLInputElement;
      const discountCheckbox = this.querySelector('.discount-checkbox') as HTMLInputElement;

      const durationLabel = this.querySelector('.duration-label');
      const imagesLabel = this.querySelector('.images-label');
      const priceDisplay = this.querySelector('.price-display');
      const originalPriceDisplay = this.querySelector('.original-price-display');

      // Wir wählen jetzt alle generierten Elemente über ihre CSS-Klasse aus
      const standardFeatures = this.querySelectorAll('.feature-standard');
      const discountFeatures = this.querySelectorAll('.feature-discount');
      const standardFooters = this.querySelectorAll('.footer-standard');
      const discountFooters = this.querySelectorAll('.footer-discount');

      if (!durationSlider || !imagesSlider || !durationLabel || !imagesLabel || !priceDisplay || !discountCheckbox || !originalPriceDisplay) return;

      const updatePrice = () => {
        const duration = parseInt(durationSlider.value, 10);
        const images = parseInt(imagesSlider.value, 10);
        const isDiscounted = discountCheckbox.checked;

        // UI Labels updaten (Minuten & Stückzahl)
        if (durationLabel) durationLabel.textContent = `Shooting-Zeit: ${duration} Minuten`;
        if (imagesLabel) imagesLabel.textContent = `Bearbeitete Bilder: ${images} Stück`;

        // Preise berechnen
        const basePrice = calculatePackagePrice(duration, images);
        const finalPrice = calculatePackagePrice(duration, images, isDiscounted ? 0.5 : 1);

        // Anzeige updaten
        if (priceDisplay) priceDisplay.textContent = formatPsychologicalPrice(finalPrice);

        // Dynamischer Wechsel zwischen Rabatt-Ansicht und Normal-Ansicht
        if (isDiscounted) {
          if (originalPriceDisplay) {
            originalPriceDisplay.textContent = formatPsychologicalPrice(basePrice);
            originalPriceDisplay.classList.remove('hidden');
          }
          // Alle Elemente in den Listen austauschen
          standardFeatures.forEach(el => el.classList.replace('flex', 'hidden'));
          discountFeatures.forEach(el => el.classList.replace('hidden', 'flex'));

          standardFooters.forEach(el => el.classList.replace('grid', 'hidden'));
          discountFooters.forEach(el => el.classList.replace('hidden', 'grid'));
        } else {
          if (originalPriceDisplay) {
            originalPriceDisplay.classList.add('hidden');
          }
          // Alle Elemente in den Listen austauschen
          standardFeatures.forEach(el => el.classList.replace('hidden', 'flex'));
          discountFeatures.forEach(el => el.classList.replace('flex', 'hidden'));

          standardFooters.forEach(el => el.classList.replace('hidden', 'grid'));
          discountFooters.forEach(el => el.classList.replace('grid', 'hidden'));
        }
      };

      // Event Listener binden
      durationSlider.addEventListener('input', updatePrice);
      imagesSlider.addEventListener('input', updatePrice);
      discountCheckbox.addEventListener('change', updatePrice);
    }
  }

  // Element im Browser registrieren
  if (!customElements.get('custom-pricing-builder')) {
    customElements.define('custom-pricing-builder', CustomPricingBuilder);
  }
</script>