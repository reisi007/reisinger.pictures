---
import type { GetStaticPaths } from "astro";
import { getCollection, render } from "astro:content";

import BaseHead from "../../layouts/BaseHead.astro";
import MinimalPage from "../../layouts/pages/MinimalPage.astro";
import SocialImage from "../../layouts/SocialImage.astro";
import { generateContactLink } from "../../utils";

export const getStaticPaths = (async () => {
  const tfpEntries = await getCollection("tfp");
  return tfpEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await render(entry);

const { title, heroImage, description: frontmatterDesc, keywords } = entry.data;

// NEU: Nimmt die explizite Description oder baut einen SEO-optimierten Fallback
const description = frontmatterDesc ?? `Kostenloses TFP Fotoshooting in Linz: Bewirb dich jetzt für das kreative Fotoprojekt "${title}" und erweitere dein Model-Portfolio.`;

const contactUrl = generateContactLink({
  subject_prefix: "TFP",
  message: `Hallo Florian,\n\nich möchte mich sehr gerne für dein TFP-Projekt "${title}" bewerben.\n\nLiebe Grüße,\n`
});
---

<MinimalPage>
  {/* NEU: Keywords werden an BaseHead weitergereicht, Titel wird für Google erweitert */}
  <BaseHead title={`${title} | TFP Shooting Linz`} {description} {keywords} slot="head">
    {heroImage && <SocialImage name={heroImage} />}
  </BaseHead>

  <div class="max-w-3xl mx-auto pt-4">

    <h1 class="text-4xl md:text-5xl font-black mb-10 text-primary leading-tight">{title}</h1>

    <div class="prose prose-lg prose-base-content/80 mb-16">
      <Content />
    </div>

    <div class="card bg-base-200/50 border border-base-300 shadow-sm not-prose">
      <div class="card-body items-center text-center p-8 md:p-12">
        <span class="mdi--camera-front-variant text-5xl text-primary opacity-80 mb-2"></span>
        <h2 class="card-title text-2xl mb-2">Interesse geweckt?</h2>
        <p class="opacity-80 mb-8 max-w-md">Schreib mir einfach eine kurze Nachricht und wir besprechen die Details für unsere gemeinsame kreative Arbeit in Linz und Umgebung.</p>
        <a href={contactUrl} class="btn btn-primary btn-lg w-full sm:w-auto shadow-lg hover:-translate-y-0.5 transition-transform">
          Jetzt als Model bewerben
        </a>
      </div>
    </div>
  </div>
</MinimalPage>