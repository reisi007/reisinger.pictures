---
import { mainLinks } from "../data/Menue";
import HeaderLogo from "./HeaderLogo.astro";

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === "/" && currentPath === "/") return true;
  if (href !== "/" && currentPath.startsWith(href)) return true;
  return false;
}
---

<header class="w-full bg-base-100/90 backdrop-blur-sm sticky top-0 z-50 border-b border-base-200 mb-4">
  <div class="navbar container mx-auto px-4 sm:px-0">
    <div class="navbar-start">
      <HeaderLogo />
    </div>

    <div class="navbar-center hidden lg:flex">
      <ul class="menu menu-horizontal px-1 gap-1 text-base font-medium z-50">
        {mainLinks.map(item => {
          if ("href" in item) {
            return (
              <li>
                <a href={item.href} target={item.external ? "_blank" : undefined} rel={item.external ? "noopener noreferrer" : undefined}
                   class={isActive(item.href) ? "text-primary font-semibold" : ""}>
                  {item.label} {item.external && <span class="icon-[mdi--open-in-new] text-xs opacity-50"></span>}
                </a>
              </li>
            );
          }
        })}
      </ul>
    </div>

    <div class="navbar-end gap-2">
      <button onclick="document.getElementById(`contact_modal`).showModal();" class="btn btn-primary btn-sm md:btn-md shadow-md flex">
        Jetzt kontaktieren
      </button>
      <button id="mobile-menu-btn" aria-label="open menu" class="btn btn-ghost btn-circle lg:hidden">
        <span class="icon-[mdi--menu] text-2xl"></span>
      </button>
    </div>
  </div>
</header>

<div id="mobile-menu-overlay" class="fixed inset-0 bg-base-100 z-100 hidden opacity-0 transition-opacity duration-300">
  <div class="bg-base-100 border-b border-base-200 sticky top-0 z-10 w-full min-h-16">
    <div class="container mx-auto px-4 flex justify-between items-center min-h-16">
      <HeaderLogo />
      <button id="mobile-menu-close" aria-label="close menu" class="btn btn-ghost btn-circle">
        <span class="icon-[mdi--close] text-2xl"></span>
      </button>
    </div>
  </div>

  <div class="grow overflow-y-auto pb-24">
    <div class="container mx-auto px-4 py-4 flex flex-col h-full">
      <ul class="menu menu-lg w-full p-0 gap-2">
        {mainLinks.map(item => {
          if ("href" in item) {
            return (
              <li>
                <a href={item.href} target={item.external ? "_blank" : undefined} rel={item.external ? "noopener noreferrer" : undefined}
                   class={isActive(item.href) ? "active font-bold text-primary" : ""}>
                  {item.label} {item.external && <span class="icon-[mdi--open-in-new] text-base opacity-50"></span>}
                </a>
              </li>
            );
          }
        })}
      </ul>
      <div class="mt-6 text-center px-4">
        <button onclick="document.getElementById(`contact_modal`).showModal(); document.getElementById(`mobile-menu-close`).click();" class="btn btn-primary btn-block shadow-md">
          <span class="icon-[mdi--message-text] text-xl"></span> Jetzt anfragen
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener("astro:page-load", () => {
    const btnOpen = document.getElementById("mobile-menu-btn");
    const btnClose = document.getElementById("mobile-menu-close");
    const overlay = document.getElementById("mobile-menu-overlay");

    if (btnOpen && btnClose && overlay) {
      const openMenu = () => {
        overlay.classList.remove("hidden");
        overlay.classList.add("flex", "flex-col");
        void overlay.offsetWidth;
        overlay.classList.remove("opacity-0");
        overlay.classList.add("opacity-100");
        document.body.style.overflow = "hidden";
      };

      const closeMenu = () => {
        overlay.classList.remove("opacity-100");
        overlay.classList.add("opacity-0");
        document.body.style.overflow = "";
        setTimeout(() => {
          overlay.classList.remove("flex", "flex-col");
          overlay.classList.add("hidden");
        }, 300);
      };

      btnOpen.addEventListener("click", openMenu);
      btnClose.addEventListener("click", closeMenu);

      const links = overlay.querySelectorAll("a");
      links.forEach(link => {
        link.addEventListener("click", closeMenu);
      });
    }
  });
</script>
