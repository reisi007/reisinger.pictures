---
import { type CollectionEntry, render } from "astro:content";

import { tryGetImage } from "../images/Images";
import ResponsiveImage from "./ResponsiveImage.astro";
import ReviewAvatar from "./ReviewAvatar.astro";
import ReviewSocialLink from "./ReviewSocialLink.astro";
import { type ReviewProps } from "./Types";

type Props = CollectionEntry<"testimonials"> & ReviewProps;

const entry = Astro.props;
const {
  id: slug,
  data: { name, source, role, layout: frontmatterLayout, large: optLargeImage, small: optSmallImage, imageFit },
  displayLargeImage = true,
  layout = frontmatterLayout
} = entry;
const smallName = optSmallImage ?? `${slug}-small`;
const largeName = optLargeImage ?? `${slug}-large`;
const small = tryGetImage(smallName);
const large = tryGetImage(largeName);
const { Content } = await render(entry);
---

{layout === "quote" ? (
  <div data-slug={import.meta.env.DEV ? slug : undefined} class="card sm:card-side bg-base-200 shadow-sm border border-base-300">
    {small !== undefined &&
      <figure class="sm:w-1/3 sm:min-w-48 p-6 sm:p-8 flex items-center justify-center shrink-0">
        <ReviewAvatar name={smallName} imageFit={imageFit} containerClass="size-32 sm:size-48 shadow-md" paddingClass="p-4 sm:p-6" sizes="(max-width: 640px) 128px, 192px" widths={[128, 192]} />
      </figure>
    }
    <div class="card-body justify-center">
      <div class="text-5xl text-primary opacity-40 -mb-6 font-serif leading-none">❝</div>
      <div class="prose prose-lg italic">
        <Content />
      </div>
      <div class="text-5xl text-primary opacity-40 -mb-6 text-right font-serif leading-none">❞</div>
      <div>
        <p class="font-bold text-lg m-0!">{name}</p>
        {role && <p class="text-sm opacity-70 m-0!">{role}</p>}
      </div>
    </div>
    {source !== undefined && <ReviewSocialLink source={source} class="right-6 top-6" />}
  </div>
) : (
  <div data-slug={import.meta.env.DEV ? slug : undefined} class="card bg-base-300 shadow-sm">
    {small !== undefined &&
      <div class="pt-8 flex justify-center">
        <ReviewAvatar name={smallName} imageFit={imageFit} containerClass="size-32 shadow-sm" paddingClass="p-3" sizes="128px" widths={[128]} />
      </div>}
    <h4 class="card-title">{name}</h4>
    {displayLargeImage && large !== undefined &&
      <ResponsiveImage name={largeName} />
    }
    <div />
    <div class="card-body">
      <Content />
    </div>
    {source !== undefined && <ReviewSocialLink source={source} class="right-6" />}
  </div>
)}