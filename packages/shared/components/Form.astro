---
const actionUrl = "https://form.reisinger.pictures";
const nextUrl = new URL(Astro.url.pathname + '?sent=true', Astro.url.origin).href;
---
<p class="text-base-content/60 text-sm text-center mb-4">Teile mir dein Projekt mit – ich melde mich zeitnah bei dir.</p>
<form id="reisinger-contact-form" method="POST" action={actionUrl} class="flex flex-col w-full max-w-lg mx-auto gap-y-2 not-prose">
  <input type="hidden" name="_next" value={nextUrl} />
  <input type="hidden" id="form-subject" name="subject" value="Allgemeine Anfrage" />
  <input type="hidden" id="form__subject_prefix" name="subject_prefix" value="" />

  <label for="form__name" class="form-control w-full">
    <span class="label ml-2 mb-1">
      <span class="label-text">Name</span>
      <span class="label-text-alt text-error">*</span>
    </span>
    <input
      type="text"
      id="form__name"
      name="name"
      required
      class="input w-full border-2 border-base-content/20 bg-base-100 text-base-content focus:border-primary focus:ring-2 focus:ring-primary/50 focus:outline-none transition-all"
    />
  </label>

  <label for="form_email" class="form-control w-full">
    <span class="label ml-2 mb-1">
      <span class="label-text">Email</span>
      <span class="label-text-alt text-error">*</span>
    </span>
    <input type="email" id="form_email" name="email" required class="input w-full border-2 border-base-content/20 bg-base-100 text-base-content focus:border-primary focus:ring-2 focus:ring-primary/50 focus:outline-none transition-all" />
  </label>

  <label for="form__phone" class="form-control w-full">
    <span class="label ml-2 mb-1">
      <span class="label-text">Telefonnummer</span>
    </span>
    <input type="tel" id="form__phone" name="phone" class="input w-full border-2 border-base-content/20 bg-base-100 text-base-content focus:border-primary focus:ring-2 focus:ring-primary/50 focus:outline-none transition-all" />
  </label>

  <label for="form_msg" class="form-control w-full">
    <span class="label ml-2 mb-1">
      <span class="label-text">Nachricht</span>
      <span class="label-text-alt text-error">*</span>
    </span>
    <textarea name="message" id="form_msg" rows="5" required class="textarea w-full border-2 border-base-content/20 bg-base-100 text-base-content focus:border-primary focus:ring-2 focus:ring-primary/50 focus:outline-none transition-all"></textarea>
  </label>

  <span class="hidden">
    Bitte nicht ausfüllen: <input type="checkbox" name="dsgvo" />
  </span>
  <input type="hidden" name="honeypot" value="6786c25a-b4fc-800d-b3c6-fa0d36f41154" />
  <div class="w-full flex justify-center">
    <button type="submit" class="btn btn-lg btn-primary mt-4">Nachricht senden</button>
  </div>

  <script>
    document.addEventListener("astro:page-load", () => {
      const form = document.getElementById("reisinger-contact-form") as HTMLFormElement;
      const modal = document.getElementById("contact_modal") as HTMLDialogElement;
      if (!form) return;

      // Referenzen auf die Felder holen
      const nameInput = document.getElementById("form__name") as HTMLInputElement;
      const subjectInput = document.getElementById("form-subject") as HTMLInputElement;

      // Zentrale Funktion für das Subject
      const updateSubject = () => {
        if (!nameInput || !subjectInput) return;
        subjectInput.value = nameInput.value.trim()
          ? "Neue Nachricht von " + nameInput.value.trim()
          : "Allgemeine Anfrage";
      };

      const fillForm = (params: URLSearchParams) => {
        for (const [key, value] of params.entries()) {
          const element = form.elements.namedItem(key);
          if (element instanceof HTMLInputElement || element instanceof HTMLTextAreaElement || element instanceof HTMLSelectElement) {
            element.value = value;
          }
        }
        // Update ausführen, falls Name via URL-Parameter kam
        updateSubject();
      };

      // Event-Listener für Tastatureingaben registrieren
      if (nameInput) {
        nameInput.addEventListener("input", updateSubject);
      }

      // 1. Initial aus URL-Parametern befüllen
      fillForm(new URLSearchParams(window.location.search));

      // 2. WICHTIG FÜR BROWSER-BACK:
      // Falls der Browser den Namen aus dem Cache wiederhergestellt hat,
      // setzen wir das Subject jetzt einmalig beim Page-Load passend zum aktuellen Wert.
      updateSubject();

      if (modal) {
        modal.addEventListener("close", () => {
          if (window.location.hash === "#kontakt" || window.location.search !== "") {
            history.replaceState(null, "", window.location.pathname);
          }
        });
      }

      if (window.location.hash === "#kontakt" && modal) {
        modal.showModal();
      }

      document.addEventListener("click", (e) => {
        const link = (e.target as HTMLElement)?.closest("a[href*='#kontakt']");
        if (!link) return;
        const targetUrl = new URL((link as HTMLAnchorElement).href);
        if (targetUrl.pathname === window.location.pathname) {
          e.preventDefault();
          fillForm(targetUrl.searchParams);
          history.pushState(null, "", targetUrl.href);
          if (modal && !modal.open) {
            modal.showModal();
          }
        }
      });
    });
  </script>
  <script>
    document.addEventListener("astro:page-load", () => {
      const params = new URLSearchParams(window.location.search);
      if (params.get("sent") !== "true") return;

      history.replaceState(null, "", window.location.pathname);

      const toast = document.createElement("div");
      toast.className = "toast toast-end toast-bottom";
      toast.innerHTML = `
        <div role="alert" class="alert alert-success shadow-lg">
          <span class="icon-[mdi--check-circle] text-xl"></span>
          <span>Nachricht erfolgreich versandt!</span>
        </div>`;
      document.body.appendChild(toast);

      setTimeout(() => {
        toast.style.transition = "opacity 0.4s";
        toast.style.opacity = "0";
        setTimeout(() => toast.remove(), 400);
      }, 4000);
    });
  </script>
</form>
